# 复制本文件为同目录下的 .env 后填写敏感或环境相关项：
#   copy .env.example .env   (Windows: copy .env.example .env)
# 切勿将 .env 提交到版本库。
#
# 非敏感项（DEBUG、端口、nginx、CAPCUT_MATE_URL、WEB_ROOT_DIR 等）已写在 docker-compose.yaml。

# ---------- 大模型（阿里云 DashScope 等，按实际填写）----------
LLM_PROVIDER=aliyun
LLM_API_KEY=
LLM_MODEL=qwen-plus
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ---------- ASR（DashScope）----------
ASR_PROVIDER=funasr
ASR_API_KEY=
ASR_API_URL=https://dashscope.aliyuncs.com/api/v1/services/audio/asr/transcription
ASR_TASK_URL=https://dashscope.aliyuncs.com/api/v1/tasks

# ---------- 腾讯云 COS ----------
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET_NAME=
COS_REGION=ap-guangzhou
